{
  "name": "youth-leader-dashboard",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "build": "next build --webpack",
    "build:web": "next build --webpack",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip",
    "dist:win": "npm run build:web && electron-builder --win nsis",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.hannah.youthleaderdashboard",
    "productName": "Youth Leader Dashboard",
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.1",
    "dexie-react-hooks": "^4.4.0",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
